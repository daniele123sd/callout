PORT=4173
NODE_ENV=development
APP_ORIGIN=http://127.0.0.1:4173
DB_URI=mongodb://127.0.0.1:27017/callout
JWT_SECRET=replace-with-a-long-random-access-token-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-refresh-token-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://127.0.0.1:4173/api/auth/google/callback
ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
ADSENSE_SLOT_HEADER=
ADSENSE_SLOT_SIDEBAR=
ADSENSE_SLOT_RIGHT_RAIL=
ADSENSE_SLOT_IN_FEED=
ADSENSE_SLOT_FOOTER=
GA_MEASUREMENT_ID=G-XXXXXXXXXX
GA_PROPERTY_ID=
GA_CLIENT_EMAIL=
GA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Add https://your-domain.example/api/admin/reporting/callback to the Google OAuth web client's authorised redirect URIs.
ADMIN_EMAILS=owner@example.com
FEATURE_CREATOR_GUILDS=true
FEATURE_RICH_COMPOSER=true
FEATURE_NOTIFICATION_CONTROLS=true
FEATURE_PROFILE_STUDIO=true
BOTS_ENABLED=true
# Minimum 60. Production default: one automated action every 360 minutes.
BOT_INTERVAL_MINUTES=360
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_VOICE_SPARK=
ELEVENLABS_VOICE_DEBATE=
ELEVENLABS_VOICE_CALM=
# Per signed-in user per day. Cached audio does not call ElevenLabs again.
TTS_DAILY_LIMIT=8
